{
  "name": "neobit-example",
  "version": "2.5.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "android:dev": "npm run start:reset & sleep 5 && npm run android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "start:reset": "react-native start --reset-cache",
    "start:verbose": "react-native start --verbose",
    "test": "jest",
    "clean": "watchman watch-del-all && rm -rf node_modules && rm -rf /tmp/metro-* && npm install",
    "clean:metro": "watchman watch-del-all && rm -rf node_modules && npm install",
    "android:clean": "cd android && ./gradlew clean && cd .. && npm run clean"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/auth": "^24.0.0",
    "@react-native-firebase/remote-config": "^24.0.0",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "axios": "^1.16.0",
    "i18next": "^26.0.8",
    "neobit-builder": "file:..",
    "react": "19.2.3",
    "react-i18next": "^17.0.6",
    "react-native": "0.85.1",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-paper": "^5.15.1",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.24.0",
    "react-native-vector-icons": "^10.3.0",
    "zod": "^4.4.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "^20.1.3",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "^20.1.3",
    "@react-native/babel-preset": "0.85.1",
    "@react-native/metro-config": "0.85.1",
    "jest": "^29.6.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
