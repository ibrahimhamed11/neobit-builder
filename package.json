{
  "name": "create-neobit-app",
  "version": "2.8.5",
  "description": "Scaffold a production-ready React Native app in one command. Auth, Firebase, Theme, i18n (Arabic + English RTL), Navigation — all wired up.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "bin": {
    "create-neobit-app": "cli/index.js"
  },
  "files": [
    "cli",
    "template",
    "src",
    "lib"
  ],
  "scripts": {
    "start": "node cli/index.js",
    "prepare": "echo ok",
    "android": "cd example && npm run android",
    "ios": "cd example && npm run ios",
    "example:start": "cd example && npm run start",
    "example:android": "cd example && npm run android",
    "example:ios": "cd example && npm run ios",
    "example:clean": "cd example && npm run clean",
    "build": "node scripts/build.js",
    "typecheck": "tsc --noEmit",
    "publish": "npm publish --access public",
    "fix-metro": "node scripts/fix-metro.js"
  },
  "keywords": [
    "react-native",
    "cli",
    "template",
    "firebase",
    "authentication",
    "boilerplate",
    "starter",
    "scaffold",
    "arabic",
    "rtl",
    "i18n",
    "neobit"
  ],
  "license": "MIT",
  "author": "Ibrahim Hamed",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ibrahimhamed11/neobit-builder.git"
  },
  "homepage": "https://github.com/ibrahimhamed11/neobit-builder#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^4.1.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@react-native/babel-preset": "0.76.9",
    "@types/react": "^18.3.0",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "typescript": "^5.3.0"
  }
}
